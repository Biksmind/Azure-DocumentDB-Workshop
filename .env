# =============================================================
# Document DB in a Day — Environment Configuration
# =============================================================
# Single configuration file used by Modules 3 and 4.
#
# Setup:
#   1. Copy this file to .env
#      PowerShell: Copy-Item .env.template .env
#      bash/zsh:   cp .env.template .env
#   2. Fill in your values from Module 1 setup
#
# NOTE: Do NOT commit the .env file — it contains secrets.
# =============================================================

# --- Azure DocumentDB Connection ---
# From Module 1, Part 1.4: Azure Portal -> Azure DocumentDB -> Connection strings
# Use the primary/global read-write connection string for your cluster.
DOCUMENTDB_CONNECTION_STRING=<your_documentdb_connection_string>

# Database name created in Module 1, Part 2.3
DOCUMENTDB_DATABASE=Workshop_DB

# --- Azure OpenAI / AI Foundry ---
# From Module 1, Part 3:
#   Endpoint: AI Foundry / Azure OpenAI resource -> Keys and Endpoint
#   API key:  AI Foundry / Azure OpenAI resource -> Keys and Endpoint
# Use the resource endpoint only. Do not append /openai/v1.
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""

# Used by Module 4 agents. If you are unsure, keep the default below.
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Chat model deployment name from Module 1, Part 3.4
# Recommended for this workshop: gpt-4.1-mini
# Fallback if not available in your region: gpt-4o-mini
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1-mini

# Embedding model deployment name from Module 1, Part 3.3
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Module 3 generates reduced embeddings with 256 dimensions.
# Keep this value aligned with the vector generation scripts and indexes.
EMBEDDING_DIMENSIONS=256
